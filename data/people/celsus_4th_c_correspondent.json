{"slug": "celsus_4th_c_correspondent", "person_name": "Celsus (4th c. correspondent)", "person_name_full": "Celsus (4th c. correspondent)", "aliases": [], "person_religion": "pagan", "majority_tradition": "pagan", "display_tradition": "pagan", "religious_tradition": "epicurean", "social_role": "rhetorician", "gender": "male", "historicity": "historical", "approx_century": "2 CE", "birth_year_approx": null, "death_year_approx": null, "notes": "", "collections": ["libanius"], "n_docs": 2, "n_collections": 1, "n_adjectives_external_total": 2.0, "n_adjectives_external_unique": 2, "trait_descriptors_external": {"incapable": 1.0, "versatile": 1.0}, "described_by": {"incapable": ["Libanius"], "versatile": ["Libanius"]}, "docs": [{"doc_id": "roman_letters_libanius_8509", "title": "Letter 763", "author": "Libanius", "year": 386, "religion": "pagan", "period": "Late Empire (Constantinian)", "subject_summary": "Letter to Ἀλεξάνδρᾳ", "excerpt": "… Celsus — a man, as you know, incapable of lying — said he both saw the books and received them from Diotimus, who himself declared they belonged to your master."}, {"doc_id": "roman_letters_libanius_8521", "title": "Letter 775", "author": "Libanius", "year": 388, "religion": "pagan", "period": "Late Empire (Constantinian)", "subject_summary": "Letter to Κέλσῳ", "excerpt": "So versatile a thing did god fashion your nature. And you alone among those we know are blamed not for being lazy, but for not biting. Let nothing change you, and let not a drunken man grieve you more than Homer's praise delights you — and with the poet, all"}], "lda_pagan": {"loadings": {"topic_0": 0.0667, "topic_1": 0.7333, "topic_2": 0.0667, "topic_3": 0.0667, "topic_4": 0.0667}, "loadings_smoothed_external": {"topic_0": 0.0667, "topic_1": 0.7333, "topic_2": 0.0667, "topic_3": 0.0667, "topic_4": 0.0667}, "dominant_topic_external": 1, "dominant_label_external": "Justice"}, "lda_christian": null, "has_portrait": false}